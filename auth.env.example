# Copy this file to auth.env and fill in your Jetson login credentials.
JETSON_HOST=192.168.0.10
JETSON_PORT=22
JETSON_USER=nvidia
JETSON_PASS=your_password_here
JETSON_HTTPS_PROXY=https://user:password@proxy.example.com:443
# Optional override (auto-detected from /etc/nv_tegra_release when empty)
JETSON_L4T_TAG=tegra-l4t-r36.4.0
